{
  "name": "soundsnap",
  "version": "1.0.0",
  "description": "Shazam-achtige muziekherkenning app gebouwd met React en Vite",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host",
    "dev:server": "set BACKEND_PORT=3001&& npm --prefix server start",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "vite": "^5.0.0"
  }
}
